# rasputin-seed.env — first-node (control plane) example.
#
# Place this file, named exactly `rasputin-seed.env`, at the ROOT of the FAT
# volume labeled RASPUTIN-OS. Go by the label, not the size — the Pi image has
# several FAT partitions. The file is read once, on first boot, by `sh`.
#
# Replace the SSH key value with your own PUBLIC key line, and keep the double
# quotes — the value contains spaces. Full reference:
# https://rasputin.geekdojo.com/docs/provisioning/
RASPUTIN_NODE_ROLE=controlplane
RASPUTIN_NODE_ID=cp-1
RASPUTIN_SSH_AUTHORIZED_KEY="ssh-ed25519 REPLACE_WITH_YOUR_PUBLIC_KEY you@laptop"
